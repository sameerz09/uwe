<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree view of university subject-->
    <record id="university_subject_view_tree" model="ir.ui.view">
        <field name="name">university.subject.view.tree</field>
        <field name="model">university.subject</field>
        <field name="arch" type="xml">
            <tree string="Subject">
                <field name="code"/>
                <field name="name"/>
                <field name="type"/>
                <field name="weightage"/>
                <field name="timetable_count" string="Timetables"/>
                <field name="batch_count" string="Batches"/>
                <field name="student_count" string="Students"/>
            </tree>
        </field>
    </record>
    <!-- Form view of university subject-->
    <record id="university_subject_view_from" model="ir.ui.view">
        <field name="name">university.subject.view.form</field>
        <field name="model">university.subject</field>
        <field name="arch" type="xml">
            <form string="Subject">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_timetables"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-calendar">
                            <field name="timetable_count" widget="statinfo" string="Timetables"/>
                        </button>
                        <button name="action_open_batches"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-th-list">
                            <field name="batch_count" widget="statinfo" string="Batches"/>
                        </button>
                        <button name="action_open_students"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-users">
                            <field name="student_count" widget="statinfo" string="Students"/>
                        </button>
                    </div>
                    <widget name="web_ribbon" title="Archived" bg_color="bg-danger"
                            invisible="active == True"/>
                    <field name="active" invisible="1"/>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="parent_subject_id"/>
                            <field name="type"/>
                            <field name="subject_style"/>
                            <field name="is_language"/>
                        </group>
                        <group>
                            <field name="name"/>
                            <field name="weightage"/>
                            <field name="is_lab"/>
                            <field name="is_theory"/>
                            <field name="pass_mark"/>
                        </group>
                        <field name="description"
                               placeholder="Enter description here"/>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>
    <!-- Menu action of university subject-->
    <!-- Search view with archived filter -->
    <record id="university_subject_view_search" model="ir.ui.view">
        <field name="name">university.subject.view.search</field>
        <field name="model">university.subject</field>
        <field name="arch" type="xml">
            <search string="Subject">
                <field name="name" string="Subject"/>
                <field name="code"/>
                <separator/>
                <filter string="Archived" name="archived" domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>

    <record id="university_subject_action" model="ir.actions.act_window">
        <field name="name">Subject</field>
        <field name="res_model">university.subject</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'active_test': True}</field>
        <field name="search_view_id" ref="university_subject_view_search"/>
    </record>

    <menuitem parent="menu_university_configuration_root"
              name="Subject Management"
              id="menu_university_subject_management" sequence="1"
    />
    <menuitem action="university_subject_action"
              parent="menu_university_subject_management"
              id="university_subject_menu"/>
</odoo>
