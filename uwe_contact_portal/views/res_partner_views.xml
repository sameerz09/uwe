<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_partner_form_portal_user_button" model="ir.ui.view">
            <field name="name">res.partner.form.portal.user.button</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="base.view_partner_form"/>
            <field name="arch" type="xml">
                <xpath expr="//div[@name='button_box']" position="inside">
                    <button name="action_open_portal_user"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-user-circle">
                        <field name="portal_user_count" widget="statinfo"
                               string="Portal User"/>
                    </button>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
