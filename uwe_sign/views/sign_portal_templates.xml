<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data>

<!-- ══════════════════════════════════════════════════
     Document List
════════════════════════════════════════════════════ -->
<template id="portal_sign_list" name="My Documents to Sign">
    <t t-call="portal.portal_layout">
        <t t-set="breadcrumbs_searchbar" t-value="True"/>
        <div class="o_portal_wrap">
            <div class="container mt-4">
                <div class="row">
                    <div class="col-12">
                        <h3 class="mb-4">Documents to Sign</h3>
                        <t t-if="not documents">
                            <div class="alert alert-info">
                                No documents awaiting your signature.
                            </div>
                        </t>
                        <t t-if="documents">
                            <table class="table table-bordered o_portal_my_doc_table">
                                <thead class="thead-light">
                                    <tr>
                                        <th>Reference</th>
                                        <th>Document</th>
                                        <th>Status</th>
                                        <th>Signed Date</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="documents" t-as="doc">
                                        <tr>
                                            <td><span t-esc="doc.ref"/></td>
                                            <td><a t-attf-href="/my/sign/#{doc.id}"><t t-esc="doc.name"/></a></td>
                                            <td>
                                                <span t-if="doc.state == 'waiting'"
                                                      class="badge badge-warning">Waiting Signature</span>
                                                <span t-if="doc.state == 'signed'"
                                                      class="badge badge-success">Signed</span>
                                                <span t-if="doc.state == 'refused'"
                                                      class="badge badge-danger">Refused</span>
                                            </td>
                                            <td><span t-esc="doc.signed_date" t-options="{'widget': 'date'}"/></td>
                                            <td>
                                                <a t-if="doc.state == 'waiting'"
                                                   t-attf-href="/my/sign/#{doc.id}"
                                                   class="btn btn-sm btn-primary">Sign</a>
                                                <a t-if="doc.state == 'signed'"
                                                   t-attf-href="/my/sign/#{doc.id}"
                                                   class="btn btn-sm btn-outline-secondary">View</a>
                                            </td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </t>
                    </div>
                </div>
            </div>
        </div>
    </t>
</template>

<!-- ══════════════════════════════════════════════════
     Document Detail + Sign Button
════════════════════════════════════════════════════ -->
<template id="portal_sign_document" name="Sign Document">
    <t t-call="portal.portal_layout">
        <div class="o_portal_wrap">
            <div class="container mt-4 mb-5">

                <!-- Breadcrumb -->
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="/my/sign">Documents</a></li>
                        <li class="breadcrumb-item active" t-esc="document.name"/>
                    </ol>
                </nav>

                <!-- Success banner -->
                <t t-if="success">
                    <div class="alert alert-success alert-dismissible fade show">
                        <strong>Document signed successfully!</strong>
                        <button type="button" class="close" data-dismiss="alert">&#215;</button>
                    </div>
                </t>

                <div class="card shadow-sm">
                    <!-- Card header -->
                    <div class="card-header d-flex justify-content-between align-items-center py-3">
                        <div>
                            <h4 class="mb-0" t-esc="document.name"/>
                            <small class="text-muted" t-esc="document.ref"/>
                        </div>
                        <div>
                            <span t-if="document.state == 'waiting'"
                                  class="badge badge-warning px-3 py-2">Waiting Signature</span>
                            <span t-if="document.state == 'signed'"
                                  class="badge badge-success px-3 py-2">Signed</span>
                            <span t-if="document.state == 'refused'"
                                  class="badge badge-danger px-3 py-2">Refused</span>
                        </div>
                    </div>

                    <!-- Document content -->
                    <div class="card-body">
                        <t t-if="document.document_content">
                            <div class="uwe-sign-doc-content border rounded p-3 mb-4"
                                 t-out="document.document_content"/>
                        </t>
                        <t t-if="not document.document_content">
                            <p class="text-muted">No document content available.</p>
                        </t>
                    </div>

                    <!-- Signature section -->
                    <div class="card-footer">
                        <!-- Already signed -->
                        <t t-if="document.state == 'signed'">
                            <div class="d-flex align-items-center">
                                <div class="mr-4">
                                    <img t-attf-src="data:image/png;base64,#{document.signature.decode() if document.signature else ''}"
                                         class="uwe-sign-saved-signature" alt="Signature"/>
                                </div>
                                <div>
                                    <p class="mb-1"><strong>Signed by:</strong> <t t-esc="document.signed_by"/></p>
                                    <p class="mb-0 text-muted">
                                        <t t-esc="document.signed_date" t-options="{'widget':'datetime'}"/>
                                    </p>
                                </div>
                            </div>
                        </t>

                        <!-- Sign button -->
                        <t t-if="document.state == 'waiting'">
                            <div class="text-right">
                                <button type="button" class="btn btn-primary uwe-sign-open-dialog"
                                        t-att-data-doc-id="document.id"
                                        t-att-data-user-name="user_name">
                                    <i class="fa fa-pen mr-1"/> Sign
                                </button>
                            </div>
                        </t>
                    </div>
                </div>
            </div>
        </div>

        <!-- ══ Signature Dialog Modal ══ -->
        <div id="uweSignModal" class="modal fade" tabindex="-1" role="dialog"
             aria-labelledby="uweSignModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-lg" role="document">
                <div class="modal-content">

                    <!-- Header -->
                    <div class="modal-header">
                        <h5 class="modal-title" id="uweSignModalLabel">Adopt Your Signature</h5>
                        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                            <span aria-hidden="true">&#215;</span>
                        </button>
                    </div>

                    <!-- Body -->
                    <div class="modal-body p-0">

                        <!-- Tab nav -->
                        <div class="uwe-sign-tabs d-flex align-items-center px-3 pt-3 pb-0 border-bottom">
                            <button class="uwe-sign-tab-btn active" data-tab="auto">Auto</button>
                            <button class="uwe-sign-tab-btn" data-tab="draw">Draw</button>
                            <button class="uwe-sign-tab-btn" data-tab="load">Load</button>
                            <button type="button" class="btn btn-link ml-auto uwe-sign-clear-btn"
                                    title="Clear">
                                <i class="fa fa-trash text-danger"/>
                            </button>
                        </div>

                        <!-- Auto tab -->
                        <div class="uwe-sign-tab-panel p-3" id="uweTabAuto">
                            <div class="uwe-sign-name-input mb-3">
                                <input type="text" id="uweSignName" class="form-control"
                                       placeholder="Type your name"/>
                            </div>
                            <div class="uwe-sign-canvas-wrap border rounded">
                                <canvas id="uweCanvasAuto" width="740" height="220"/>
                            </div>
                        </div>

                        <!-- Draw tab -->
                        <div class="uwe-sign-tab-panel p-3 d-none" id="uweTabDraw">
                            <div class="uwe-sign-canvas-wrap border rounded" style="cursor:crosshair;">
                                <canvas id="uweCanvasDraw" width="740" height="220"/>
                            </div>
                            <p class="text-muted small mt-2 mb-0">Draw your signature above.</p>
                        </div>

                        <!-- Load tab -->
                        <div class="uwe-sign-tab-panel p-3 d-none" id="uweTabLoad">
                            <div class="custom-file mb-3">
                                <input type="file" class="custom-file-input" id="uweSignFile"
                                       accept="image/*"/>
                                <label class="custom-file-label" for="uweSignFile">
                                    Choose image file…
                                </label>
                            </div>
                            <div class="uwe-sign-canvas-wrap border rounded">
                                <canvas id="uweCanvasLoad" width="740" height="220"/>
                            </div>
                        </div>

                        <!-- Disclaimer -->
                        <div class="px-3 pb-3">
                            <p class="text-muted small mt-2 mb-0">
                                By clicking Adopt &amp; Sign, I agree that the chosen signature/initials
                                will be a valid electronic representation of my hand-written signature/initials
                                for all purposes.
                            </p>
                        </div>
                    </div>

                    <!-- Footer -->
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                        <button type="button" class="btn btn-primary" id="uweAdoptAndSign">
                            Adopt &amp; Sign
                        </button>
                    </div>

                </div>
            </div>
        </div>
        <!-- ══ End Modal ══ -->

    </t>
</template>

</data>
</odoo>
