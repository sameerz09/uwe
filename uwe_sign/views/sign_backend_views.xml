<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- List View -->
        <record id="view_uwe_sign_document_tree" model="ir.ui.view">
            <field name="name">uwe.sign.document.tree</field>
            <field name="model">uwe.sign.document</field>
            <field name="arch" type="xml">
                <tree string="Sign Documents" decoration-success="state=='signed'"
                      decoration-warning="state=='waiting'" decoration-muted="state=='refused'">
                    <field name="ref"/>
                    <field name="name"/>
                    <field name="employee_id"/>
                    <field name="partner_id"/>
                    <field name="state" widget="badge"
                           decoration-success="state=='signed'"
                           decoration-warning="state=='waiting'"
                           decoration-danger="state=='refused'"
                           decoration-info="state=='draft'"/>
                    <field name="signed_by"/>
                    <field name="signed_date"/>
                </tree>
            </field>
        </record>

        <!-- Form View -->
        <record id="view_uwe_sign_document_form" model="ir.ui.view">
            <field name="name">uwe.sign.document.form</field>
            <field name="model">uwe.sign.document</field>
            <field name="arch" type="xml">
                <form string="Sign Document">
                    <header>
                        <button name="action_send_for_signature" string="Send for Signature"
                                type="object" class="btn-primary"
                                invisible="state != 'draft'"/>
                        <button name="action_refuse" string="Refuse"
                                type="object" class="btn-danger"
                                invisible="state not in ['waiting']"/>
                        <button name="action_reset_to_draft" string="Reset to Draft"
                                type="object"
                                invisible="state not in ['refused', 'signed']"/>
                        <field name="state" widget="statusbar"
                               statusbar_visible="draft,waiting,signed"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name" placeholder="Document Name..."/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="ref" readonly="1"/>
                                <field name="employee_id"/>
                                <field name="partner_id"/>
                            </group>
                            <group>
                                <field name="signed_by" readonly="1"/>
                                <field name="signed_date" readonly="1"/>
                                <field name="signature" widget="image" readonly="1"
                                       invisible="not signature"
                                       style="max-height:80px;"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Document Content">
                                <field name="document_content" widget="html"/>
                            </page>
                            <page string="Attachments">
                                <field name="attachment_ids" widget="many2many_binary"/>
                            </page>
                        </notebook>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids"/>
                        <field name="activity_ids"/>
                        <field name="message_ids"/>
                    </div>
                </form>
            </field>
        </record>

        <!-- Search View -->
        <record id="view_uwe_sign_document_search" model="ir.ui.view">
            <field name="name">uwe.sign.document.search</field>
            <field name="model">uwe.sign.document</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="employee_id"/>
                    <field name="ref"/>
                    <filter string="Waiting" name="waiting" domain="[('state','=','waiting')]"/>
                    <filter string="Signed" name="signed" domain="[('state','=','signed')]"/>
                    <filter string="Draft" name="draft" domain="[('state','=','draft')]"/>
                    <group expand="0" string="Group By">
                        <filter string="Status" name="group_state" context="{'group_by':'state'}"/>
                        <filter string="Employee" name="group_employee" context="{'group_by':'employee_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Action -->
        <record id="action_uwe_sign_document" model="ir.actions.act_window">
            <field name="name">Sign Documents</field>
            <field name="res_model">uwe.sign.document</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="view_uwe_sign_document_search"/>
        </record>

        <!-- Menu -->
        <menuitem id="menu_uwe_sign_root" name="UWE Sign" sequence="90"/>
        <menuitem id="menu_uwe_sign_documents" name="Documents"
                  parent="menu_uwe_sign_root"
                  action="action_uwe_sign_document" sequence="10"/>

    </data>
</odoo>
